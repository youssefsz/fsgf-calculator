---
import { ClientRouter } from "astro:transitions"

import SEOHead from "@/components/seo/SEOHead.astro"
import Header from "@/components/navigation/Header.astro"
import NavProgress from "@/components/navigation/NavProgress.astro"
import ThemeScript from "@/components/theme/ThemeScript.astro"
import { en } from "@/i18n/en"
import { fr } from "@/i18n/fr"
import type { Locale, RouteKey } from "@/i18n/routes"
import { ROUTES } from "@/i18n/routes"
import "@/styles/global.css"

interface Props {
  title: string
  description: string
  locale: Locale
  alternates: Record<Locale, string>
  canonicalPath: string
  currentRoute: RouteKey
}

const { title, description, locale, alternates, canonicalPath, currentRoute } =
  Astro.props
const t = locale === "fr" ? fr : en
const siteUrl = Astro.site?.toString() ?? "http://localhost:4321"
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <SEOHead
      title={title}
      description={description}
      locale={locale}
      alternates={alternates}
      canonicalPath={canonicalPath}
      siteUrl={siteUrl}
    />
    <ThemeScript />
    <ClientRouter />
  </head>
  <body class="flex min-h-svh flex-col bg-background text-foreground">
    <NavProgress />
    <Header locale={locale} t={t} alternates={alternates} currentRoute={currentRoute} />
    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
      <slot />
    </main>
    <footer class="mt-auto border-t border-border">
      <div class="mx-auto flex w-full max-w-5xl flex-col gap-4 px-4 py-8 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1">
          <p class="text-sm text-muted-foreground">
            &copy; {new Date().getFullYear()} {t.site.name}. {t.footer.rights}
          </p>
          <p class="text-xs text-muted-foreground">
            {t.footer.openSource} · {t.footer.createdBy}{" "}
            <a
              href="https://youssef.tn"
              target="_blank"
              rel="noopener noreferrer"
              class="underline transition-colors hover:text-foreground"
            >
              Youssef Dhibi
            </a>
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/youssefsz/fsgf-calculator"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            aria-label={t.footer.sourceCode}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span>{t.footer.sourceCode}</span>
          </a>
          <nav class="flex items-center gap-4">
            <a
              href={ROUTES.privacy[locale]}
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              {t.footer.privacy}
            </a>
            <a
              href={ROUTES.terms[locale]}
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              {t.footer.terms}
            </a>
          </nav>
        </div>
      </div>
      <div class="border-t border-border px-4 py-4 text-center text-xs text-muted-foreground">
        <div class="mx-auto max-w-5xl">
          {t.footer.notOfficial}{" "}
          <a
            href="http://www.parcours-lmd.salima.tn"
            target="_blank"
            rel="noopener noreferrer"
            class="underline transition-colors hover:text-foreground"
          >
            parcours-lmd.salima.tn
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
