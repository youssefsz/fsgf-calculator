---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { Calculator } from "@/features/calculator/Calculator"
import { en } from "@/i18n/en"
import { getAlternateRoutes, ROUTES } from "@/i18n/routes"

const locale = "en" as const
const t = en
const alternates = getAlternateRoutes("home")
const title = t.seo.titleTemplate.replace("{title}", t.calculator.title)
const preselectedCode = Astro.url.searchParams.get("code") ?? undefined
---

<BaseLayout
  title={title}
  description={t.site.description}
  locale={locale}
  alternates={alternates}
  canonicalPath={ROUTES.home[locale]}
  currentRoute="home"
>
  <div transition:animate="none">
    <Calculator locale={locale} preselectedCode={preselectedCode} client:load />
  </div>
</BaseLayout>
