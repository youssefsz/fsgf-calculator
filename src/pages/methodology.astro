---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { en } from "@/i18n/en"
import { getAlternateRoutes, ROUTES } from "@/i18n/routes"

const locale = "en" as const
const t = en
const alternates = getAlternateRoutes("methodology")
const title = t.seo.titleTemplate.replace("{title}", t.methodology.title)
---

<BaseLayout
  title={title}
  description={t.methodology.description}
  locale={locale}
  alternates={alternates}
  canonicalPath={ROUTES.methodology[locale]}
  currentRoute="methodology"
>
  <article class="max-w-3xl space-y-8">
    <header class="space-y-2">
      <h1 class="text-2xl font-bold tracking-tight">{t.methodology.title}</h1>
      <p class="text-muted-foreground">{t.methodology.description}</p>
    </header>

    <section class="space-y-4">
      <h2 class="text-lg font-semibold">{t.methodology.formulas}</h2>
      <dl class="divide-y divide-border border-t border-border">
        <div class="py-3">
          <dt class="font-medium">{t.methodology.mxWithTp}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.mxWithTpFormula}
          </dd>
        </div>
        <div class="py-3">
          <dt class="font-medium">{t.methodology.mxWithoutTp}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.mxWithoutTpFormula}
          </dd>
        </div>
        <div class="py-3">
          <dt class="font-medium">{t.methodology.cc}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.ccFormula}
          </dd>
        </div>
        <div class="py-3">
          <dt class="font-medium">{t.methodology.directGrade}</dt>
          <dd class="mt-1 text-sm text-muted-foreground">
            {t.methodology.directGradeDescription}
          </dd>
        </div>
      </dl>
    </section>

    <section class="space-y-4">
      <h2 class="text-lg font-semibold">{t.methodology.averages}</h2>
      <dl class="divide-y divide-border border-t border-border">
        <div class="py-3">
          <dt class="font-medium">{t.methodology.ueAverage}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.ueAverageFormula}
          </dd>
        </div>
        <div class="py-3">
          <dt class="font-medium">{t.methodology.semesterAverage}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.semesterAverageFormula}
          </dd>
        </div>
        <div class="py-3">
          <dt class="font-medium">{t.methodology.yearAverage}</dt>
          <dd class="mt-1 font-mono text-sm text-muted-foreground">
            {t.methodology.yearAverageFormula}
          </dd>
        </div>
      </dl>
    </section>

    <section class="space-y-2">
      <h2 class="text-lg font-semibold">{t.methodology.limitations}</h2>
      <p class="text-muted-foreground">{t.methodology.limitationsDescription}</p>
    </section>
  </article>
</BaseLayout>
