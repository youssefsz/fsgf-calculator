---
import ThemeScript from "@/components/theme/ThemeScript.astro"
import { en } from "@/i18n/en"
import { fr } from "@/i18n/fr"
import { ROUTES } from "@/i18n/routes"
import "@/styles/global.css"

const locale = Astro.url.pathname.startsWith("/fr") ? "fr" : "en"
const t = locale === "fr" ? fr : en
const homeHref = ROUTES.home[locale]
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>404 – {t.notFound.title}</title>
    <ThemeScript />
  </head>
  <body class="flex min-h-svh flex-col items-center justify-center bg-background text-foreground">
    <div class="relative flex flex-col items-center justify-center px-4 text-center">
      <span
        class="pointer-events-none absolute inset-0 flex items-center justify-center select-none"
        aria-hidden="true"
      >
        <span class="text-[20rem] font-black leading-none tracking-tighter text-muted-foreground/10 sm:text-[28rem] md:text-[36rem]">
          404
        </span>
      </span>

      <div class="relative z-10 flex flex-col items-center gap-6">
        <div class="flex flex-col items-center gap-3">
          <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            {t.notFound.title}
          </h1>
        </div>

        <p class="max-w-md text-muted-foreground">
          {t.notFound.description}
        </p>

        <a
          href={homeHref}
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/80 focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6" />
          </svg>
          {t.notFound.backHome}
        </a>
      </div>
    </div>
  </body>
</html>
